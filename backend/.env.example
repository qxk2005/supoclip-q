# faster-whisper model size (tiny, base, small, medium, large, …)
WHISPER_MODEL_SIZE=medium

# LLM Providers
OPENAI_API_KEY=
# Optional: OpenAI-compatible proxy (e.g. third-party gateways); omit for api.openai.com
OPENAI_BASE_URL=
OPENAI_MODEL=GLM-4.7-FP8
GOOGLE_API_KEY=
YOUTUBE_DATA_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=

# The AI Model to use throughout the app
LLM=openai:GLM-4.7-FP8

# Prevent tasks from sitting in queued forever if worker is down
QUEUED_TASK_TIMEOUT_SECONDS=180

# YouTube metadata lookup provider: `yt_dlp` or `youtube_data_api`
YOUTUBE_METADATA_PROVIDER=yt_dlp

# Processing defaults
DEFAULT_PROCESSING_MODE=fast
FAST_MODE_MAX_CLIPS=4
FAST_MODE_TRANSCRIPT_MODEL=tiny
BALANCED_MODE_TRANSCRIPT_MODEL=medium
QUALITY_MODE_TRANSCRIPT_MODEL=large-v3

# Good for speed optimizations
COMPOSE_BAKE=true

# DB
POSTGRES_DB=supoclip
POSTGRES_USER=supoclip
POSTGRES_PASSWORD=supoclip_password

# Discord webhook URLs (each posts to a separate channel)
DISCORD_FEEDBACK_WEBHOOK_URL=
DISCORD_SALES_WEBHOOK_URL=

# Monetization (only enabled when SELF_HOST=false)
SELF_HOST=true
BACKEND_AUTH_SECRET=change_me_backend_auth_secret
AUTH_SIGNATURE_TTL_SECONDS=300
CORS_ORIGINS=http://localhost:3000,http://sp.localhost:3000
# Hosted mode currently requires paid subscription to process tasks.
FREE_PLAN_TASK_LIMIT=10
PRO_PLAN_TASK_LIMIT=0
